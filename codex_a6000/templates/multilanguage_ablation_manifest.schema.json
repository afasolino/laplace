{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laplace.local/schemas/multilanguage_ablation_manifest.schema.json",
  "title": "32-task multilanguage dual-model ablation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "task_count",
    "language_counts",
    "regression_task_ids",
    "defaults",
    "tasks"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "benchmark_id": {"const": "multilanguage_dual_model_ablation_v1"},
    "task_count": {"const": 32},
    "language_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "c", "verilog", "systemverilog"],
      "properties": {
        "python": {"const": 8},
        "c": {"const": 8},
        "verilog": {"const": 8},
        "systemverilog": {"const": 8}
      }
    },
    "regression_task_ids": {"type": "array", "minItems": 6, "maxItems": 6},
    "defaults": {"type": "object"},
    "tasks": {
      "type": "array",
      "minItems": 32,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "language",
          "category",
          "regression",
          "fixture",
          "editable_sources",
          "public_tests",
          "held_out_id",
          "objective",
          "requirements",
          "required_tools",
          "routing"
        ],
        "properties": {
          "task_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
          "language": {"enum": ["python", "c", "verilog", "systemverilog"]},
          "category": {"enum": ["implementation", "repair", "edge_case", "integration"]},
          "regression": {"type": "boolean"},
          "fixture": {"type": "string", "minLength": 1},
          "editable_sources": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "public_tests": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "held_out_id": {"type": "string", "minLength": 1},
          "objective": {"type": "string", "minLength": 10},
          "requirements": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "required_tools": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "routing": {"type": "object"}
        }
      }
    }
  }
}
