{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laplace.local/schemas/model_artifact_profiles.schema.json",
  "title": "Pinned model artifacts for the serialized ablation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "quantization_environment", "calibration", "artifacts"],
  "properties": {
    "schema_version": {"const": 1},
    "quantization_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "llmcompressor", "llmcompressor_revision", "transformers", "datasets", "huggingface_hub", "vllm"],
      "properties": {
        "python": {"const": "3.11"},
        "llmcompressor": {"const": "0.12.0"},
        "llmcompressor_revision": {"pattern": "^[0-9a-f]{40}$"},
        "transformers": {"const": "5.13.1"},
        "datasets": {"const": "5.0.0"},
        "huggingface_hub": {"const": "1.23.0"},
        "vllm": {"const": "0.25.0"}
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "split", "samples", "shuffle_seed"],
      "properties": {
        "repository": {"const": "HuggingFaceH4/ultrachat_200k"},
        "revision": {"pattern": "^[0-9a-f]{40}$"},
        "split": {"const": "train_sft"},
        "samples": {"const": 256},
        "shuffle_seed": {"const": 42}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "phase", "role", "source_repository", "source_revision", "licence_identifier", "source_path", "output_path", "served_model_name", "availability_policy", "quantization", "serving", "verification"],
        "properties": {
          "artifact_id": {"enum": ["phase1_main", "phase2_main", "phase2_rtl_worker"]},
          "phase": {"enum": ["phase1", "phase2"]},
          "role": {"enum": ["main", "rtl_worker"]},
          "source_repository": {"type": "string", "pattern": "^https://huggingface\\.co/"},
          "source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "licence_identifier": {"type": "string", "minLength": 1},
          "source_path": {"type": "string", "minLength": 1},
          "output_path": {"type": "string", "minLength": 1},
          "served_model_name": {"type": "string", "minLength": 1},
          "availability_policy": {"enum": ["installed_official_artifact", "requires_local_quantization"]},
          "quantization": {"type": "object"},
          "serving": {"type": "object"},
          "verification": {"type": "object"}
        }
      }
    }
  }
}
