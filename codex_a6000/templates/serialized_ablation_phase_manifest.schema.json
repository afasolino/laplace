{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laplace.local/schemas/serialized_ablation_phase_manifest.schema.json",
  "title": "Serialized ablation execution phase manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "phase_id",
    "phase_label",
    "status",
    "active_configuration",
    "expected_model_identities",
    "fingerprint",
    "started_at",
    "completed_at",
    "wall_elapsed_seconds",
    "sum_completed_task_seconds",
    "runtime_definition",
    "task_arm_pairs_completed",
    "task_arm_pairs_terminal_failures",
    "task_arm_pairs_attempted_terminal",
    "expected_pairs",
    "decoding_settings",
    "tool_versions",
    "gpu_memory_observations",
    "endpoint_health",
    "server_lifecycle",
    "output_paths"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "experiment_id": {"const": "multilanguage_dual_model_ablation_v1"},
    "phase_id": {"enum": ["phase1", "phase2", "phase3"]},
    "phase_label": {"type": "string", "minLength": 1},
    "status": {"enum": ["RUNNING", "COMPLETE", "INCOMPLETE", "INCOMPATIBLE"]},
    "active_configuration": {"type": "array", "minItems": 1, "maxItems": 1},
    "expected_model_identities": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"type": "string"}},
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_revision",
        "benchmark_sha256",
        "experiment_sha256",
        "model_artifacts_sha256",
        "model_configuration_hashes",
        "corpus_hashes",
        "held_out_manifest_sha256",
        "evaluation_settings_sha256",
        "result_schema_version",
        "evaluation_protocol_version"
      ],
      "properties": {
        "base_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "benchmark_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "experiment_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "model_artifacts_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "model_configuration_hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["A", "B", "C"],
          "properties": {
            "A": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "B": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "C": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "corpus_hashes": {"type": "object"},
        "held_out_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "evaluation_settings_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "result_schema_version": {"const": 2},
        "evaluation_protocol_version": {"const": "failure-accounting-v2"}
      }
    },
    "started_at": {"type": "string", "minLength": 1},
    "completed_at": {"type": ["string", "null"]},
    "wall_elapsed_seconds": {"type": ["number", "null"], "minimum": 0},
    "sum_completed_task_seconds": {"type": "number", "minimum": 0},
    "runtime_definition": {"type": "string", "minLength": 1},
    "task_arm_pairs_completed": {"type": "array", "maxItems": 32},
    "task_arm_pairs_terminal_failures": {"type": "array", "maxItems": 32},
    "task_arm_pairs_attempted_terminal": {"type": "integer", "minimum": 0, "maximum": 32},
    "expected_pairs": {"const": 32},
    "decoding_settings": {"type": "object"},
    "tool_versions": {"type": "object"},
    "gpu_memory_observations": {"type": "object"},
    "endpoint_health": {"type": "object"},
    "server_lifecycle": {"type": "object"},
    "output_paths": {"type": "object"}
  }
}
