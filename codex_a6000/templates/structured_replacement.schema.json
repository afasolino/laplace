{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.laplace/schemas/structured-replacement.schema.json",
  "title": "Hash-bound full-file replacement plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "replacements"],
  "properties": {
    "schema_version": {"const": 1},
    "replacements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "language", "kind", "expected_sha256", "content"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "language": {"enum": ["python", "systemverilog"]},
          "kind": {"enum": ["source", "testbench"]},
          "expected_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "content": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
